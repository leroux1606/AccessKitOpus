# Database
DATABASE_URL=postgresql://user:password@localhost:5432/accesskit

# Auth
AUTH_SECRET=generate-a-strong-secret-here
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Resend (email magic link + transactional emails)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@accesskit.app

# Stripe (international / legacy)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
STRIPE_PROFESSIONAL_MONTHLY_PRICE_ID=price_...
STRIPE_PROFESSIONAL_ANNUAL_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_...
STRIPE_AUDIT_PRICE_ID=price_...

# PayStack (primary payment processor)
# Sign up at https://paystack.com — create plans in dashboard, then paste codes below
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_STARTER_MONTHLY_PLAN_CODE=PLN_...
PAYSTACK_STARTER_ANNUAL_PLAN_CODE=PLN_...
PAYSTACK_PROFESSIONAL_MONTHLY_PLAN_CODE=PLN_...
PAYSTACK_PROFESSIONAL_ANNUAL_PLAN_CODE=PLN_...
PAYSTACK_AGENCY_MONTHLY_PLAN_CODE=PLN_...
PAYSTACK_AGENCY_ANNUAL_PLAN_CODE=PLN_...

# AI (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Storage (Cloudflare R2)
# Screenshots of every scanned page are uploaded to R2 and linked from
# reports. Uploads are skipped entirely if ANY of the five vars below is
# missing, so local dev works fine without R2 — pages just get a null
# screenshotUrl. `R2_PUBLIC_URL` must be the publicly reachable base
# (custom domain or R2 `pub-*.r2.dev` subdomain) — without it the
# S3 endpoint object URL requires signed reads and can't be embedded.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=accesskit-screenshots
R2_PUBLIC_URL=

# Force-disable screenshot capture even when R2 is configured (e.g. to
# skip it in staging). Any value other than exactly "false" is ignored.
SCANNER_CAPTURE_SCREENSHOTS=

# Scanning Worker
# When production-deployed, the `scan-website` Inngest function runs on the
# dedicated Fly.io worker (see `Dockerfile`, `fly.toml`, `worker/README.md`).
# Leave `RUN_SCANS_IN_NEXT` unset (or set to anything other than "true") in
# the web tier so only the worker advertises the function to Inngest Cloud.
# In local development (`NODE_ENV=development`) the web tier registers the
# function automatically so `pnpm dev` works standalone.
RUN_SCANS_IN_NEXT=

# Opt-in pa11y second-pass (spawns an extra Chromium per URL — ~+300 MB RSS)
SCANNER_ENABLE_PA11Y=false

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Monitoring
SENTRY_DSN=https://...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
